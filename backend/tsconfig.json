{
  "compilerOptions": {
    /* File structure */
    "rootDir": "src",
    "outDir": "dist",

    /* Module / target settings for Node ES modules */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type checking */
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,

    /* Output options */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,                 /* must be false to produce JS */
    "skipLibCheck": true,            /* ignore checking node_modules for faster builds */

    /* Node globals */
    "lib": ["ESNext"],               /* required for Node globals */
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}